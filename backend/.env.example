# Required: path to the read-only DuckDB database file
DUCKDB_PATH=path/to/duckdb/file.duckdb

# Optional: directory where DuckDB extensions are pre-installed (set in the Docker image)
# DUCKDB_EXTENSION_DIRECTORY=/opt/duckdb/extensions

# Test mode: load .env.test instead of .env and allow FTS INSTALL at runtime
# TESTING=false

# Comma-separated CORS origins (* allows all origins — suitable for local dev only)
# CORS_ALLOWED_ORIGINS=*

# Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# DuckDB connection pragmas
# DUCKDB_THREADS=4
# DUCKDB_MEMORY_LIMIT=1GB
