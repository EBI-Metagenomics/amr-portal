# API (browser calls this path; ingress often maps /amr/api → backend)
VITE_API_BASE_URL=/amr/api

# Public prefix for Eleventy marketing pages (must match frontend pathPrefix, without trailing slash).
VITE_PORTAL_PREFIX=/amr

# Vite asset base + React Router basename (defaults to {VITE_PORTAL_PREFIX}/data/ if unset)
VITE_APP_BASE=/amr/data/
