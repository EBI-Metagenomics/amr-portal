# API (browser calls this path; ingress often maps /amr/api → backend)
VITE_API_BASE_URL=/amr/api

# Public prefix for Eleventy marketing pages (must match frontend pathPrefix, without trailing slash).
VITE_PORTAL_PREFIX=/amr

# Vite asset base + React Router basename (defaults to {VITE_PORTAL_PREFIX}/data/ if unset)
VITE_APP_BASE=/amr/data/

# Genome browser: off unless true. Local dev: set here. K8s: same variable names on the pod env (ConfigMap → env); entrypoint writes runtime-config.js.
VITE_ENABLE_GENOME_VIEWER=true

# FASTA root (bgzip `.fa.gz`, `.fai`, `.gzi`). Docker build uses a placeholder; set on the pod env for runtime.
VITE_GENOME_FASTA_BASE_URL=https://ftp.ebi.ac.uk/pub/databases/metagenomics/jbrowse_files/amr_portal/genomes

# GFF root (bgzip `_annotations.gff.gz`, `.csi`). Often the same host as FASTA; use a second variable when trees differ.
VITE_GENOME_GFF_BASE_URL=https://ftp.ebi.ac.uk/pub/databases/metagenomics/jbrowse_files/amr_portal/genomes
